# ─── MVP (optionnel) ───────────────────────────────────────────────
# L'application fonctionne sans ces variables en production.
# Les formulaires sont validés côté serveur et journalisés dans les logs Vercel.

# URL publique du site (recommandé en production pour le SEO / Open Graph)
# Exemple : https://ninetyfour.vercel.app ou https://www.ninetyonefoot.com
NEXT_PUBLIC_SITE_URL="https://your-domain.vercel.app"

# ─── Phase 2 — Supabase / PostgreSQL ───────────────────────────────
# À configurer quand la base de données sera branchée.

DATABASE_URL="postgresql://user:password@localhost:5432/ninetyone?schema=public"
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ─── Phase 2 — Emails (Resend) ──────────────────────────────────────────────
# Utilisés par la page /rejoindre pour :
# - envoyer le PDF au candidat (lien signé si Supabase est configuré)
# - notifier l’admin à chaque inscription
#
# Important : côté production, à configurer sur Vercel (variables serveur).
RESEND_API_KEY="your-resend-api-key"
ADMIN_EMAIL="admin@your-domain.com"
SENDER_EMAIL="no-reply@your-domain.com"


